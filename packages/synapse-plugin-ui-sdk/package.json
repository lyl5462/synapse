{
  "name": "@synapse/plugin-ui-sdk",
  "version": "1.0.0",
  "description": "Frontend SDK for Synapse Plugin 2.0 UI — communicates with the host via postMessage bridge",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/synapse/synapse.git",
    "directory": "packages/synapse-plugin-ui-sdk"
  },
  "keywords": ["synapse", "plugin", "sdk", "bridge"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
